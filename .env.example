# Environment Variables
# Create a .env file locally with these variables. 
# Do NOT commit your actual .env file to version control.

# Set to 'production' to enable secure headers and disable debug mode
FLASK_ENV=development

# A long, random string used to securely sign session cookies (Change in production!)
SECRET_KEY=dev-secret-key-replace-in-prod-very-long-string

# A long, random string used to sign JWT tokens for the API (Change in production!)
JWT_SECRET_KEY=jwt-super-secret-key-replace-in-prod

# Database connection string. SQLite is default, but for Render you might use Postgres
# Example Postgres: postgresql://username:password@hostname:port/database_name
DATABASE_URL=sqlite:///todo.db
